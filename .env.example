# Example config for the news scheduled task.
# Copy this to ~/.config/news/env and edit it for yourself.
# install.sh copies it automatically if missing. A leading ~ in a path expands to your home.
# Do not put secrets here (Gmail credentials live in ~/.config/news-gmail/).
#
# Out of the box only "news collection" runs. Gmail and blog-idea-scout are optional add-ons.

# ============================================================
# Core: daily-news (news collection)
# ============================================================
# Output directory (the morning/evening Markdown digests)
NEWS_DIR=~/news

# Language to write the digest in (e.g. English, Japanese, Spanish). Default: English
OUTPUT_LANGUAGE=English

# Weather location. Leave empty to omit the weather section
WEATHER_LOCATION=Tokyo

# Categories to collect. Separated by `;`. Each item may be `name: hint`
NEWS_CATEGORIES=AI/ML: new models, tools, research; Software engineering: languages, frameworks, outages; Engineering management: org, hiring, culture; World news

# (optional) Preferred sources, `;`-separated. Empty = the agent picks per category
NEWS_SOURCES=Hacker News; TechCrunch; The Verge; Ars Technica

# (optional) Days to keep the digests. After each run, YYYY-MM-DD-{morning|evening}.md
# files in NEWS_DIR older than this are deleted (needs an allowlist entry — see README).
# 0 or empty = keep forever
NEWS_RETENTION_DAYS=0

# ============================================================
# Optional: Gmail "needs action" mail (morning digest)
#   Leave GMAIL_ENABLED=0 if you don't use it (this block is ignored).
#   To use it, set up OAuth via daily-news/gmail/SETUP.md.
# ============================================================
GMAIL_ENABLED=0
GMAIL_QUERY=is:unread -category:promotions -category:social newer_than:14d
GMAIL_MAX=40

# ============================================================
# Optional: Google Calendar "today's schedule" (morning digest)
#   Leave CALENDAR_ENABLED=0 if you don't use it.
#   To use it, set up OAuth via daily-news/calendar/SETUP.md.
# ============================================================
CALENDAR_ENABLED=0
# `;`-separated calendar IDs. Default `primary`. Other IDs: Calendar settings -> Integrate calendar -> Calendar ID
CALENDAR_IDS=primary
# How many days ahead beyond today. 0 = today only, 1 = today + tomorrow (default)
CALENDAR_DAYS_AHEAD=1
CALENDAR_MAX=50
# Per-field length cap (summary/location) so one bloated event can't swell the digest. Default: 200
CALENDAR_MAX_FIELD_LEN=200

# ============================================================
# Optional: blog-idea-scout (blog post idea suggestions)
#   Only used if installed via ./install.sh --with-blog-idea-scout.
#   Ignore this block otherwise.
# ============================================================
# Where suggestions are written
BLOG_IDEA_FILE=~/blog-ideas.md
# One line: your blog's character and what makes a good idea
BLOG_PROFILE=A personal, analysis-and-experience-driven tech blog. An idea only works when fresh news connects to your own past notes/posts
# (optional) Existing idea backlog file. Used for dedup if set
BACKLOG_FILE=
# (optional) Path to a past-notes search command. Used to mine related notes if set
VAULT_SEARCH=
